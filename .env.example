# ===========================================================================
# 2026-1-DSCD-ADE-01 Environment Variables
# ---------------------------------------------------------------------------
# 이 파일을 복사하여 `.env`로 저장한 뒤 실제 값을 채워 사용한다.
#   cp .env.example .env
#
# `.env`는 git 추적에서 제외된다(.gitignore 참조).
# 배포 환경(Cloud Run 등)에서는 OS 환경변수로 주입하며, OS 환경변수가
# `.env`보다 우선 적용된다.
# ===========================================================================

# ---- GCP ----
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# ---- Cloud SQL (pgvector) ----
# 형식: <project>:<region>:<instance>
CLOUD_SQL_CONNECTION=your-gcp-project-id:us-central1:your-db-instance
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name

# ---- Cloud Storage ----
GCS_BUCKET=your-gcs-bucket-name

# ---- Models (선택값, 기본값 존재) ----
GEMINI_MODEL=gemini-2.5-flash

# ---- Document AI (Document OCR processor) ----
# 콘솔 → Document AI → Processors에서 확인.
# DOCAI_LOCATION 예: "us" 또는 "eu" (Vertex AI의 location과 다를 수 있음).
DOCAI_LOCATION=us
DOCAI_PROCESSOR_ID=your-docai-processor-id
DOCAI_LAYOUT_PROCESSOR_ID=your-docai-layout-processor-id
DOCAI_LAYOUT_PROCESSOR_VERSION=pretrained-layout-parser-v1.5-2025-08-25

# ---- LAW API ---
LAW_API_KEY=your_law_api_key
